generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ThoughtNode {
  id             String        @id @default(cuid())
  title          String
  slug           String        @unique
  content        String
  branchQuestion String?
  branchLabel    String?
  sortOrder      Int           @default(0)
  tags           String        @default("")
  published      Boolean       @default(true)
  parentId       String?
  parent         ThoughtNode?  @relation("ThoughtTree", fields: [parentId], references: [id], onDelete: Cascade)
  children       ThoughtNode[] @relation("ThoughtTree")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([parentId])
  @@index([published])
}
