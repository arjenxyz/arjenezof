# Supabase — Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
# Sunucu anahtarı: sb_secret_... (Secret keys). Publishable key DEĞİL.
SUPABASE_SECRET_KEY="sb_secret_..."
# Eski projeler için (legacy JWT, eyJ...): SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# Site URL (sitemap, paylaşım linkleri) — üretimde https://arjenezof.vercel.app gibi
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Admin girişi — üretimde mutlaka güçlü değerler kullanın
ADMIN_PASSWORD="degistir-beni"
ADMIN_SECRET="uzun-rastgele-bir-gizli-anahtar-en-az-32-karakter"

# Aile alanı — ilk kurulumda varsayılan şifreler (admin panelden değiştirilebilir)
# Boş bırakılırsa: aile-wife-degistir, aile-children-degistir, aile-grandchildren-degistir
FAMILY_PASSWORD_WIFE=""
FAMILY_PASSWORD_CHILDREN=""
FAMILY_PASSWORD_GRANDCHILDREN=""
