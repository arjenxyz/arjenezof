# Supabase PostgreSQL
# Project Settings → Database → Connection string
#
# Uygulama (Vercel / npm run dev) — Transaction pooler, port 6543:
# DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
#
# Migration / db push — Session/direct, port 5432:
# DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

DATABASE_URL=""
DIRECT_URL=""

# Admin girişi — üretimde mutlaka güçlü değerler kullanın
ADMIN_PASSWORD="degistir-beni"
ADMIN_SECRET="uzun-rastgele-bir-gizli-anahtar-en-az-32-karakter"
